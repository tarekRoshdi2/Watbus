generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model crm_backups {
  id         String    @id
  data       Json
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model users {
  id                    String               @id @default(dbgenerated("gen_random_uuid()"))
  username              String               @unique
  password_hash         String
  subscription_status   subscription_status? @default(trial)
  subscription_end_date DateTime?            @db.Timestamptz(6)
  created_at            DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at            DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  tokens_used           Int?                 @default(0)
  messages_sent         Int?                 @default(0)
  cost_incurred         Decimal?             @default(0.00) @db.Decimal(10, 2)

  @@index([username], map: "idx_users_username")
  
  devices   Device[]
  campaigns Campaign[]
  folders   Folder[]
  tickets   Ticket[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model whatsapp_sessions {
  id           String    @id
  device_id    String
  file_path    String
  file_content String
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)
}

enum subscription_status {
  active
  trial
  inactive
}


// ==========================================
// NEW CHATCORE ENTERPRISE MODELS
// ==========================================

model Device {
  id                  String   @id @default(uuid())
  name                String
  phoneNumber         String?
  phoneId             String?
  method              String   @default("cloud_api")
  status              String   @default("offline")
  tenantId            String
  userId              String?
  user                users?   @relation(fields: [userId], references: [id])
  flowStagesEnabled   Boolean  @default(true)
  flowStages          Json?
  
  aiAgentEnabled      Boolean  @default(false)
  aiAgentName         String?
  aiAgentInstructions String?
  aiModel             String?  @default("gemini-1.5-flash")
  aiTemperature       Float    @default(0.7)
  aiKnowledgeBase     String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  conversations       Conversation[]
}

model Conversation {
  id              String   @id @default(uuid())
  deviceId        String
  device          Device   @relation(fields: [deviceId], references: [id])
  contactPhone    String
  contactName     String?
  status          String   @default("open")
  label           String   @default("None")
  unreadCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  messages        Message[]
  tags            ConversationTag[]
  tickets         Ticket[]
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  recipientId    String
  content        String?
  type           String   @default("text")
  mediaUrl       String?
  status         String   @default("sent")
  timestamp      DateTime @default(now())
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#000000")
  tenantId  String
  
  conversations ConversationTag[]
}

model ConversationTag {
  conversationId String
  tagId          String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  tag            Tag          @relation(fields: [tagId], references: [id])
  
  @@id([conversationId, tagId])
}

model Campaign {
  id           String   @id @default(uuid())
  name         String
  status       String   @default("draft")
  userId       String
  user         users    @relation(fields: [userId], references: [id])
  deviceId     String
  tenantId     String
  targetTagId  String?
  message      String
  interval     Int      @default(1000)
  progress     Int      @default(0)
  total        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#000000")
  tenantId  String
  userId    String
  user      users    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id             String       @id @default(uuid())
  title          String
  status         String       @default("open")
  priority       String       @default("normal")
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  assignedToId   String?
  assignedTo     users?       @relation(fields: [assignedToId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
